#version 450

// ============================================================================
// 顶点着色器 - 带纹理坐标的四边形渲染
// ============================================================================
//
// 功能：渲染一个四边形（由两个三角形组成），每个顶点包含位置和纹理坐标
//
// 顶点数据编码方式：
//   vec4 的 .xy 分量存储顶点位置
//   vec4 的 .zw 分量存储纹理坐标（UV 坐标）
//
// ============================================================================
//
// Vulkan 图形管线中的坐标变换流程：
//   顶点着色器输出 gl_Position (裁剪坐标)
//              ↓
//           GPU 透视除法
//              ↓
//           NDC 坐标 [-1, 1]
//              ↓
//           视口变换
//              ↓
//           屏幕坐标（像素）
//
// Vulkan NDC 坐标系：
//       +X
//        │
//        │
//        │
//        └──── +Y (向下)
//       ╱
//      ╱
//     +Z（指向屏幕外）
//
// 范围：[-1, 1] × [-1, 1]
//
// ============================================================================

// 输出变量：纹理坐标（传递给片段着色器）
layout(location = 0) out vec2 uv;
//                         ↑
//                    纹理坐标，范围 [0, 1]

// 顶点数组：6 个顶点（2 个三角形，共享 2 个顶点）
vec4 vertices[6] = {
    // 顶点 0: 左下角
    //           xy: (-0.5, 0.5)  = x=-0.5(左), y=0.5(下，Y正向下)
    //           zw: (0.0, 1.0)   = 纹理左下角
    vec4(-0.5, 0.5, 0.0, 1.0),

    // 顶点 1: 左上角
    //           xy: (-0.5, -0.5) = x=-0.5(左), y=-0.5(上，Y负向上)
    //           zw: (0.0, 0.0)   = 纹理左上角
    vec4(-0.5, -0.5, 0.0, 0.0),

    // 顶点 2: 右上角
    //           xy: (0.5, -0.5)  = x=0.5(右), y=-0.5(上)
    //           zw: (1.0, 0.0)   = 纹理右上角
    vec4(0.5, -0.5, 1.0, 0.0),

    // 顶点 3: 右上角（与顶点 2 相同，第二个三角形复用）
    vec4(0.5, -0.5, 1.0, 0.0),

    // 顶点 4: 右下角
    //           xy: (0.5, 0.5)   = x=0.5(右), y=0.5(下)
    //           zw: (1.0, 1.0)   = 纹理右下角
    vec4(0.5, 0.5, 1.0, 1.0),

    // 顶点 5: 左下角（与顶点 0 相同，第二个三角形复用）
    vec4(-0.5, 0.5, 0.0, 1.0),
};

// ============================================================================
// 主函数：每个顶点执行一次
// ============================================================================
void main()
{
    // 设置顶点位置（裁剪坐标）
    // gl_Position: Vulkan 内置输出变量，输出裁剪坐标
    //              vec4(x, y, z, w)
    //
    // 坐标变换流程：
    //   1. 顶点着色器输出 gl_Position（裁剪坐标，范围：[-w, w]）
    //   2. GPU 自动执行透视除法: ndc = xyz / w
    //   3. 得到 NDC 坐标（范围：[-1, 1]）
    //
    // 当前代码：w = 1.0
    //   - 透视除法后：ndc = vec3(xy, 0.0) / 1.0 = vec3(xy, 0.0)
    //   - 因为 w = 1，所以裁剪坐标和 NDC 坐标在数值上相等
    //   - 但概念上仍然是裁剪坐标！
    //
    // 顶点位置来自 vertices[gl_VertexIndex].xy
    // z = 0.0: 2D 渲染，深度为 0（最近）
    // w = 1.0: 齐次坐标，表示这是点而不是方向
    gl_Position = vec4(vertices[gl_VertexIndex].xy, 0.0, 1.0);

    // 输出纹理坐标（传递给片段着色器）
    // uv: 从 vertices[gl_VertexIndex].zw 获取纹理坐标
    //     GPU 会在三角形内部对 uv 进行插值
    //     每个像素获得对应的纹理坐标
    uv = vertices[gl_VertexIndex].zw;
}
