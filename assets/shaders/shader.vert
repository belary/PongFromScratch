#version 450
// ============================================================================
// 顶点着色器 (Vertex Shader)
// ============================================================================
//
// 作用：处理每个顶点的数据，将其从模型空间转换到裁剪空间
//
// 执行流程：
// Vulkan 发送 3 个顶点 → 每个顶点调用一次 main() → 输出 gl_Position
// 编译命令: glslc.exe shader.vert -o shader.vert.spv
// ============================================================================

// 顶点坐标数组（硬编码的三角形）
//
// vec2: 二维向量 (x, y)
// 坐标范围：[-1, 1] × [-1, 1]（归一化设备坐标 NDC）
//
// 坐标系说明（Vulkan NDC）：
//
//      +X
//       │
//       │
//       │
//       └──── +Y (向下)
//      ╱
//     ╱
//    +Z（指向屏幕外）
//
// 重要：Vulkan 的 Y 轴正方向是向下的！
//       这与 OpenGL 不同（OpenGL Y 轴向上）
//
// 三角形顶点布局：
//        (-0.5, 0.5)  ●
//                    / \
//                   /   \
//                  /     \
//       (0, -0.5) ●-------● (0.5, 0.5)
//
// 注意：由于 Y 轴向下，y=0.5 实际在 y=-0.5 的"上方"（屏幕上方）
//
vec2 vertices[3] =
{
    vec2(-0.5, 0.5),  // 顶点 0：左下（x=-0.5, y=0.5）
    vec2(0, -0.5),    // 顶点 1：顶部中间（x=0, y=-0.5）
    vec2(0.5, 0.5)    // 顶点 2：右下（x=0.5, y=0.5）
};

void main()
{
    // ========================================================================
    // gl_Position：内置输出变量，顶点的最终位置（裁剪空间坐标）
    // ========================================================================
    //
    // vec4 构造函数：vec4(x, y, z, w)
    //
    // 参数说明：
    //   - vertices[gl_VertexIndex].x, .y: 从数组获取顶点的 X, Y 坐标
    //   - 1.0 (Z 坐标): 深度值，范围 [-1, 1]，0 是近平面，1 是远平面
    //   - 1.0 (W 坐标): 齐次坐标，用于透视投影（通常为 1）
    //
    // gl_VertexIndex：内置变量，当前顶点的索引
    // Vulkan 绘制时会自动设置：
    //   第 1 次调用：gl_VertexIndex = 0 → vertices[0] = (-0.5, 0.5)
    //   第 2 次调用：gl_VertexIndex = 1 → vertices[1] = (0, -0.5)
    //   第 3 次调用：gl_VertexIndex = 2 → vertices[2] = (0.5, 0.5)
    //
    gl_Position = vec4(vertices[gl_VertexIndex], 1.0, 1.0);

    // 注意：这里没有使用顶点缓冲区，而是硬编码了顶点数据
    //       实际项目中通常会从缓冲区读取顶点数据
}
