#version 450
// ============================================================================
// 片段着色器 (Fragment Shader)
// ============================================================================
//
// 作用：为每个像素（片段）计算最终颜色
//
// 执行时机：光栅化后，三角形覆盖的每个像素都会调用一次 main()
//
// ============================================================================

// 输出变量：片段颜色
//
// layout(location = 0): 指定这个变量的位置索引为 0
//   - 位置索引用于连接顶点着色器和片段着色器的数据
//   - 也用于 Framebuffer 的附件绑定
//
// out: 输出修饰符，表示这个变量将传递到下一阶段（Framebuffer）
//
// vec4: 四维向量 (r, g, b, a)
//   - r: 红色通道 [0, 1]
//   - g: 绿色通道 [0, 1]
//   - b: 蓝色通道 [0, 1]
//   - a: 透明度/Alpha 通道 [0, 1]，0=完全透明，1=完全不透明
//
layout(location = 0) out vec4 fragmentColor;

void main()
{
    // 设置片段颜色为白色
    //
    // vec4(1.0, 1.0, 1.0, 1.0) = RGBA(255, 255, 255, 255)
    //   - 1.0 = 最大值（8 位颜色中对应 255）
    //   - 0.0 = 最小值（8 位颜色中对应 0）
    //
    // 颜色示例：
    //   vec4(1.0, 0.0, 0.0, 1.0) = 红色
    //   vec4(0.0, 1.0, 0.0, 1.0) = 绿色
    //   vec4(0.0, 0.0, 1.0, 1.0) = 蓝色
    //   vec4(1.0, 1.0, 0.0, 1.0) = 黄色
    //   vec4(0.0, 0.0, 0.0, 1.0) = 黑色
    //   vec4(1.0, 1.0, 1.0, 1.0) = 白色
    //
    fragmentColor = vec4(1.0, 0.0, 0.0, 1.0);

    // 注意：这个着色器没有使用插值输入
    //       所有像素都是相同的颜色（纯白三角形）
    //       实际项目中通常会从顶点着色器接收插值后的颜色/纹理坐标
}
