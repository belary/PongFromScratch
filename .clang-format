---
# 基础风格
BasedOnStyle: LLVM

# 缩进与宽度
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 100

# 访问修饰符 (public/private) 的偏移
AccessModifierOffset: -4

# 大括号换行策略
# BreakBeforeBraces: Attach  # 大括号不换行（K&R 风格）
# Allman 风格：大括号在单独一行，更易读，适合学习项目
BreakBeforeBraces: Allman

# 函数与命名空间
AllowShortFunctionsOnASingleLine: Inline
AllowShortBlocksOnASingleLine: false
AllowShortIfStatementsOnASingleLine: Never

# 这里的设置对游戏循环和逻辑判断很友好
AlignAfterOpenBracket: Align
AlignConsecutiveAssignments: false
AlignConsecutiveDeclarations: false

# 指针/引用的对齐方式（推荐靠类型对齐，如 int* p）
PointerAlignment: Left

# 排序头文件（学习项目推荐禁用）
# 原因：某些头文件有严格的依赖顺序（如 windows.h 必须在 vulkan_win32.h 之前）
# 自动排序可能破坏编译，手动控制更安全
SortIncludes: false

# 针对 C++11 及更高版本的优化
Standard: Latest
...